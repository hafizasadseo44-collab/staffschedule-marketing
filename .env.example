# ─── Database ───
DATABASE_URL="file:./prisma/dev.db"

# ─── Site URL (used in every email link) ───
NEXT_PUBLIC_SITE_URL=https://staffschedule.io

# ─── Site Privacy & Access Control ───
SITE_PRIVATE_MODE=true
SITE_PASSWORD=staff2026

# ─── Admin Credentials ───
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me
JWT_SECRET=generate_a_long_random_string

# ═════════════════════════════════════════════════════════════════════
# RESEND — 3 dedicated business email senders
# ═════════════════════════════════════════════════════════════════════
RESEND_API_KEY=re_your_api_key_here

# Senders ("Display Name <email>")
#   hello@      — contact form replies, sales conversations
#   newsletter@ — broadcasts (blog, digest, product updates)
#   noreply@    — automated/transactional (welcome, system alerts)
RESEND_FROM_HELLO="StaffSchedule.io <hello@staffschedule.io>"
RESEND_FROM_NEWSLETTER="StaffSchedule.io Team <newsletter@staffschedule.io>"
RESEND_FROM_NOREPLY="StaffSchedule.io <noreply@staffschedule.io>"

# Reply-To for marketing/automated emails (route replies to a human)
RESEND_REPLY_TO_NEWSLETTER=hello@staffschedule.io
RESEND_REPLY_TO_NOREPLY=hello@staffschedule.io

# Where contact form submissions are routed
CONTACT_INBOX=hello@staffschedule.io

# ─── Cron jobs ───
CRON_SECRET=generate_with_openssl_rand_hex_16

# ─── Admin emergency rescue (optional but recommended) ───
# Visit /api/admin/rescue?token=...&newPassword=... to reset admin login.
# Must be 24+ chars. Generate with: openssl rand -hex 24
ADMIN_RESCUE_TOKEN=

# ═════════════════════════════════════════════════════════════════════
# BLOG COMMENT SYSTEM
# ═════════════════════════════════════════════════════════════════════

# Cloudflare Turnstile (CAPTCHA) — optional but strongly recommended
# Get free keys at https://dash.cloudflare.com/?to=/:account/turnstile
# When set, the blog comment form renders the Turnstile widget and the
# server verifies every submission. When empty, anti-spam falls back to
# the rate limiter + spam scoring only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# If "true", ALL new comments start as PENDING even if the commenter
# is trusted. Default is false (trusted commenters auto-approve).
MODERATE_COMMENTS=false

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
NEXT_PUBLIC_STRIPE_PRICE_TEAM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_COMPANY_MONTHLY=price_xxx

NEXT_PUBLIC_APP_URL=https://app.staffschedule.io
